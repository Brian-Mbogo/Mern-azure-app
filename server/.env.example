# Example environment variables for server
# DO NOT commit real credentials. Copy this file to `.env` and fill values locally.

# MongoDB Atlas connection string (replace <user>, <password>, <cluster>, <dbname>)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Optional: port the server listens on (Azure provides this automatically)
# PORT=3000
